{
  "files.associations": {
    "*.gpl": "gpl",
    "*.gpo": "gpl"
  },
  "gpl.trace.server": "verbose",
  "files.exclude": {
    "**/.gitattributes": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/out": true
  },
  "githubPullRequests.ignoredPullRequestBranches": [
    "main"
  ],
  "chat.tools.terminal.autoApprove": {
    "/^npm run pre-release-check$/": {
      "approve": true,
      "matchCommandLine": true
    }
  }
}
