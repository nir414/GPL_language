{
    "comments": {
        "lineComment": "'"
    },
    "brackets": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"]
    ],
    "autoClosingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""]
    ],
    "surroundingPairs": [
        ["{", "}"],
        ["[", "]"],
        ["(", ")"],
        ["\"", "\""]
    ],
    "indentationRules": {
        "increaseIndentPattern": "^\\s*(?:(?:(?:Else\\s*)?If\\b.*\\bThen\\s*(?:'.*)?$)|(?:Else\\s*(?:'.*)?$)|(?:(?:For|While|Sub|Function|Class|Module|Try|Catch|Finally|Type|Enum|Select|With|Do|Case)\\b.*))$",
        "decreaseIndentPattern": "^\\s*(?:End\\s+(?:If|For|While|Sub|Function|Class|Module|Try|Type|Select|With|Enum)|Next|Loop|Wend|Catch|Finally|Case|ElseIf|Else)\\b.*$"
    },
    "folding": {
        "markers": {
            "start": "^\\s*'\\s*#region\\b",
            "end": "^\\s*'\\s*#endregion\\b"
        }
    },
    "wordPattern": "[A-Za-z_][A-Za-z0-9_]*"
}
