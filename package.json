{
    "name": "gpl-language-support",
    "displayName": "GPL Language Support",
    "description": "GPL (Guidance Programming Language) support for Visual Studio Code - IntelliSense, Go to Definition, Find References for Brooks Automation robot control language",
    "version": "0.3.0",
    "publisher": "nir414",
    "repository": {
        "type": "git",
        "url": "https://github.com/nir414/GPL_language"
    },
    "bugs": {
        "url": "https://github.com/nir414/GPL_language/issues"
    },
    "homepage": "https://github.com/nir414/GPL_language#readme",
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Programming Languages",
        "Debuggers"
    ],
    "keywords": [
        "gpl",
        "guidance programming language",
        "brooks automation",
        "robot control",
        "motion control",
        "automation",
        "preciseflex",
        "vb.net"
    ],
    "main": "./out/extension.js",
    "activationEvents": [
        "onLanguage:gpl",
        "workspaceContains:**/*.gpl",
        "workspaceContains:**/*.gpo",
        "onView:gplThreads",
        "onCommand:gpl.refreshSymbols",
        "onCommand:gpl.debugSymbolCache",
        "onCommand:gpl.showXmlBestPractices",
        "onCommand:gpl.analyzeXmlEncoding",
        "onCommand:gpl.controller.connect",
        "onCommand:gpl.controller.disconnect",
        "onCommand:gpl.controller.discover",
        "onCommand:gpl.deploy",
        "onCommand:gpl.console.start",
        "onCommand:gpl.console.stop",
        "onCommand:gpl.threads.refresh"
    ],
    "contributes": {
        "languages": [
            {
                "id": "gpl",
                "aliases": [
                    "GPL",
                    "gpl"
                ],
                "extensions": [
                    ".gpl",
                    ".gpo"
                ],
                "configuration": "./language-configuration.json"
            }
        ],
        "grammars": [
            {
                "language": "gpl",
                "scopeName": "source.gpl",
                "path": "./syntaxes/gpl.tmGrammar.json"
            }
        ],
        "commands": [
            {
                "command": "gpl.refreshSymbols",
                "title": "GPL: Refresh Symbols"
            },
            {
                "command": "gpl.debugSymbolCache",
                "title": "GPL: Debug Symbol Cache"
            },
            {
                "command": "gpl.showXmlBestPractices",
                "title": "GPL: Show XML Best Practices"
            },
            {
                "command": "gpl.analyzeXmlEncoding",
                "title": "GPL: Analyze XML Encoding"
            },
            {
                "command": "gpl.controller.connect",
                "title": "GPL: Connect to Controller",
                "icon": "$(plug)"
            },
            {
                "command": "gpl.controller.disconnect",
                "title": "GPL: Disconnect Controller",
                "icon": "$(debug-disconnect)"
            },
            {
                "command": "gpl.controller.discover",
                "title": "GPL: Discover Controllers",
                "icon": "$(search)"
            },
            {
                "command": "gpl.deploy",
                "title": "GPL: Deploy to Controller",
                "icon": "$(rocket)"
            },
            {
                "command": "gpl.console.start",
                "title": "GPL: Start Runtime Console",
                "icon": "$(terminal)"
            },
            {
                "command": "gpl.console.stop",
                "title": "GPL: Stop Runtime Console",
                "icon": "$(stop)"
            },
            {
                "command": "gpl.threads.refresh",
                "title": "GPL: Refresh Threads",
                "icon": "$(refresh)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "gpl-controller",
                    "title": "GPL Controller",
                    "icon": "$(server)"
                }
            ]
        },
        "views": {
            "gpl-controller": [
                {
                    "id": "gplThreads",
                    "name": "Threads"
                }
            ]
        },
        "menus": {
            "view/title": [
                {
                    "command": "gpl.threads.refresh",
                    "when": "view == gplThreads",
                    "group": "navigation"
                },
                {
                    "command": "gpl.deploy",
                    "when": "view == gplThreads",
                    "group": "navigation"
                }
            ]
        },
        "configuration": {
            "type": "object",
            "title": "GPL Language Support",
            "properties": {
                "gpl.trace.server": {
                    "scope": "window",
                    "type": "string",
                    "enum": [
                        "off",
                        "messages",
                        "verbose"
                    ],
                    "default": "off",
                    "description": "Controls GPL Language Support extension tracing (Output: 'GPL Language Support')."
                },
                "gpl.controller.ip": {
                    "scope": "window",
                    "type": "string",
                    "default": "192.168.0.2",
                    "description": "Brooks controller IP address."
                },
                "gpl.controller.port": {
                    "scope": "window",
                    "type": "number",
                    "default": 1402,
                    "description": "Controller console port (TCP command interface)."
                },
                "gpl.controller.consolePort": {
                    "scope": "window",
                    "type": "number",
                    "default": 1403,
                    "description": "Controller runtime console port (live output stream)."
                },
                "gpl.controller.timeoutMs": {
                    "scope": "window",
                    "type": "number",
                    "default": 10000,
                    "description": "Command timeout in milliseconds."
                },
                "gpl.controller.ftpBasePath": {
                    "scope": "window",
                    "type": "string",
                    "default": "/GPL",
                    "description": "FTP base path on the controller for project uploads."
                },
                "gpl.controller.threadPollIntervalMs": {
                    "scope": "window",
                    "type": "number",
                    "default": 5000,
                    "description": "Thread status polling interval in milliseconds."
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "npm run compile && node scripts/package.js",
        "dev:cycle": "npm run package",
        "dev:install": "node -e \"console.error('dev:install is disabled to prevent opening new VS Code windows. Build VSIX with npm run dev:cycle, then install manually from Extensions > Install from VSIX.'); process.exit(1);\"",
        "dev:cycle:open": "node -e \"console.error('dev:cycle:open is disabled to prevent opening new VS Code windows. Use npm run dev:install only when explicit reinstall is needed.'); process.exit(1);\"",
        "dev:host": "node -e \"console.error('dev:host is disabled to prevent opening new VS Code windows.'); process.exit(1);\""
    },
    "devDependencies": {
        "@types/vscode": "^1.74.0",
        "@types/node": "16.x",
        "@vscode/vsce": "^2.26.1",
        "typescript": "^4.9.4"
    },
    "dependencies": {},
    "author": "nir414",
    "license": "MIT"
}
