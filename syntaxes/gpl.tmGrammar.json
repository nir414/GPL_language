{
    "name": "GPL",
    "scopeName": "source.gpl",
    "patterns": [
        {
            "match": "(?i)^\\s*((?:Public|Private)\\s+)?\\b(Class)\\b\\s+([a-zA-Z_]\\w*)",
            "captures": {
                "1": { "name": "storage.modifier.gpl" },
                "2": { "name": "storage.type.class.gpl" },
                "3": { "name": "entity.name.type.class.gpl" }
            },
            "name": "meta.class.declaration.gpl"
        }
    ]
}
